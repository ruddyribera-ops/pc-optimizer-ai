# PC Optimizer AI - Environment Variables Template
# Copy this to .env and fill in your values

# Database - Get this from Railway dashboard after creating PostgreSQL
DATABASE_URL=postgresql://username:password@host:port/database

# Server Configuration
PORT=8000
HOST=0.0.0.0

# AI Service (Ollama or OpenAI)
# For local development: http://localhost:11434
# For production: Use OpenAI API key below
OLLAMA_URL=http://localhost:11434

# OpenAI API (optional - for cloud AI)
OPENAI_API_KEY=sk-your-openai-key-here

# Security
SECRET_KEY=change-this-to-a-random-secret-key

# Application
APP_NAME=PC Optimizer AI
DEBUG=False